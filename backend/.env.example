# Database
DATABASE_URL=postgresql://user:password@localhost:5432/healthpractix

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Garage/S3 Storage
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=healthpractix-media
S3_ACCESS_KEY=your-garage-access-key
S3_SECRET_KEY=your-garage-secret-key
S3_PUBLIC_URL=http://localhost:3900/healthpractix-media

# Redis (OTP storage)
REDIS_URL=redis://localhost:6379

# Client JWT (mobile app auth)
CLIENT_JWT_SECRET=generate-with-node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Elastic Email (SMTP)
ELASTIC_EMAIL_HOST=smtp.elasticemail.com
ELASTIC_EMAIL_PORT=2525
ELASTIC_EMAIL_USER=your@email.com
ELASTIC_EMAIL_PASS=your-elastic-email-api-key
EMAIL_FROM_NAME=HealthPractix
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com

# Frontend URL (used in invite links)
FRONTEND_URL=http://localhost:3000

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
