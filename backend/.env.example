# ============================================================
# HealthPractix Backend — Environment Variables
# Copy to .env and fill in values before running
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
# LOG_TO_FILE=true  # Enable file logging (optional — containers should use stdout)

# ── Database (required) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/healthpractix?sslmode=require

# ── Clerk Authentication (required) ─────────────────────────
CLERK_SECRET_KEY=sk_live_xxx
CLERK_PUBLISHABLE_KEY=pk_live_xxx

# ── Client Mobile App JWT (required) ────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CLIENT_JWT_SECRET=

# ── Redis (required for Socket.io, BullMQ, caching) ────────
REDIS_URL=redis://default:password@host:6379

# ── S3 / Object Storage (required for uploads) ─────────────
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=ap-south-1
S3_BUCKET=healthpractix-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
# S3_PUBLIC_URL is only needed if you serve media directly from S3 (not via /media proxy)

# ── AWS S3 (optional — for client report uploads) ──────────
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=healthpractix-uploads

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=https://app.healthpractix.com
API_BASE_URL=https://api.healthpractix.com

# ── CORS (comma-separated allowed origins) ──────────────────
CORS_ALLOWED_ORIGINS=https://app.healthpractix.com,https://healthpractix.com

# ── Email (Elastic Email) ───────────────────────────────────
ELASTIC_EMAIL_HOST=smtp.elasticemail.com
ELASTIC_EMAIL_PORT=2525
ELASTIC_EMAIL_USER=noreply@healthpractix.com
ELASTIC_EMAIL_PASS=
EMAIL_FROM_NAME=HealthPractix
EMAIL_FROM_ADDRESS=noreply@healthpractix.com

# ── AI Providers (optional — for document summarization) ────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Image Processing ────────────────────────────────────────
# IMAGE_PROCESSING_TIMEOUT=30000  # ms, increase for large images

# ── Razorpay (subscriptions / payment links) ────────────────
# Get keys from https://dashboard.razorpay.com/app/keys (test or live).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret — random string; set the same value in Razorpay dashboard
# webhook config (Account & Settings → Webhooks).
RAZORPAY_WEBHOOK_SECRET=

# Days after renewal before an unpaid client subscription auto-pauses.
# Default 3. During grace the client app shows a payment prompt; payment
# (webhook or manual) prevents the auto-pause.
GRACE_DAYS=3
