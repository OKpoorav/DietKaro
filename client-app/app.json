{
  "expo": {
    "name": "HealthPractix",
    "slug": "healthpractix-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "scheme": "healthpractix",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#17cf54"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthpractix.client"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#17cf54"
      },
      "package": "com.healthpractix.client",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.jpg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.jpg",
          "color": "#17cf54",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.healthpractix.com/api/v1",
      "clerkPublishableKey": "pk_test_Y29oZXJlbnQtb3NwcmV5LTc5LmNsZXJrLmFjY291bnRzLmRldiQ",
      "eas": {
        "projectId": "e06a17c8-8a52-4f1f-ac23-78c6f042ef1f"
      },
      "router": {}
    },
    "owner": "okpoorav"
  }
}
